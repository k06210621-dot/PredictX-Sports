# PredictX Sports 本地開發環境變數範例
# 複製此檔為 .env 並填入實際值（.env 不會進 git）

# === 資料庫（本地 PostgreSQL）===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sports_db
DB_USER=jero
DB_PASSWORD=

# === Railway 部署時會自動注入 DATABASE_URL，本地不需設定 ===
# DATABASE_URL=postgres://user:password@host:port/dbname

# === Flask ===
FLASK_ENV=development
PORT=8081

# === Ollama ===
OLLAMA_HOST=http://localhost:11434
